# Copy to .env and fill in. .env is gitignored.

# Anthropic API key for the LLM agents (explainability / recommendation / exec-summary).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model id used by the LLM agents.
TRIALMIND_MODEL=claude-opus-4-8

# Database connection.
# Default (zero-setup, local file):
#   sqlite:///data/trialmind.db
# Production-style Postgres example:
#   postgresql+psycopg2://user:password@localhost:5432/trialmind
DATABASE_URL=sqlite:///data/trialmind.db
